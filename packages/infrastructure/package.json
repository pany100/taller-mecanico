{
  "name": "@taller/infrastructure",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "test": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "typecheck": "tsc --noEmit",
    "db:generate": "node --env-file=../../.env node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file=../../.env node_modules/drizzle-kit/bin.cjs migrate",
    "db:test:create": "node --env-file=../../.env.test scripts/create-test-db.mjs",
    "db:migrate:test": "node --env-file=../../.env.test node_modules/drizzle-kit/bin.cjs migrate"
  },
  "dependencies": {
    "@taller/application": "workspace:*",
    "@taller/domain": "workspace:*",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.21.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10"
  }
}
